                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                // =========================================
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        // BASIC VALIDATION
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                // =========================================

